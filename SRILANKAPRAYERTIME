    <script src="jaffna_prayer_data.js"></script>
    <script src="zone03_prayer_data.js"></script>
    <script src="trincomalee_prayer_data.js"></script>
    <!-- App Logic -->
    <script src="script.js"></script>
    <!-- App Logic -->
    <script src="script.js"></script>

    <script>
        // Init Icons
        lucide.createIcons();

        // PWA Registration

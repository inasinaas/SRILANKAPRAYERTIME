                    zone_data[m_idx][day] = {
                        'fajr': match.group(3),
                        'sunrise': match.group(4),
                        'luhr': match.group(5),
                        'asr': match.group(6),
                        'magrib': match.group(7),
                        'isha': match.group(8)
                    }

    # Format output as JS
    with open('badulla_prayer_data.js', 'w') as f:
        f.write('const BADULLA_PRAYER_DATA = ')
        json.dump(zone_data, f, indent=2)
        f.write(';\n')

    print("Parsed data saved to badulla_prayer_data.js")

except Exception as e:
    print("Error:", e)
